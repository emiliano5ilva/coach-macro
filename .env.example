# =============================================================================
# COACH MACRO — Environment Variable Reference
# =============================================================================
# This file is committed to git (no secrets — names + comments only).
# .env.local holds the real values and is gitignored (never committed).
#
# RECOVERY AFTER `vercel env pull`:
#   vercel env pull rewrites .env.local with only the vars Vercel's
#   development environment exposes. It clobbered .env.local twice:
#     1. Missing VITE_SUPABASE_*  → black-screen crash on launch.
#     2. Missing VITE_API_BASE_URL → all AI features silently dead.
#
#   After every pull, run:
#       npm run check-env
#   Then restore any MISSING vars from your password manager / team vault.
#   Values to keep safe: VITE_SUPABASE_*, VITE_API_BASE_URL, VITE_RAPIDAPI_KEY.
#
# SECTIONS:
#   CLIENT (VITE_*)  — baked into the web/iOS bundle at Vite build time.
#                      These must be in .env.local for local & sim builds.
#   SERVER           — used by api/ serverless functions (process.env.*).
#                      Set in Vercel dashboard; NOT needed in .env.local
#                      unless you run `vercel dev` locally.
#
# TAGS:  [BOOT]    = app crashes / shows black screen if missing.
#        [CORE]    = core feature broken (AI dead, food search dead, etc.)
#        [FEATURE] = specific integration unavailable; app boots fine.
#        [DEV]     = simulator/local dev only; empty is fine in production.
# =============================================================================


# =============================================================================
# CLIENT VARS  (VITE_*)
# check-env verifies these exist in .env.local before build:sim runs.
# =============================================================================

# [BOOT] Supabase project REST/auth URL.
# Absent → "supabaseUrl is required." crash at module init → black screen.
VITE_SUPABASE_URL=__set_me__

# [BOOT] Supabase anonymous public key (safe to expose to browser).
# Absent → same boot crash as VITE_SUPABASE_URL.
VITE_SUPABASE_ANON_KEY=__set_me__

# [CORE] Base URL for the Vercel serverless proxy (all AI features).
# Used in src/client.js as: fetch(`${API_BASE}/api/claude`).
# Absent → API_BASE="" → fetch hits localhost/api/claude → AI silently dead.
VITE_API_BASE_URL=https://www.coach-macro.com

# [FEATURE] Same base URL for PhotoFoodLogger + food database services.
# Should match VITE_API_BASE_URL. Has || '' fallback; photo-log & food DB break if absent.
VITE_API_BASE=https://www.coach-macro.com

# [FEATURE] RapidAPI key for food search (USDA / branded food database).
# Absent → food search returns no results; has || '' fallback so app boots.
VITE_RAPIDAPI_KEY=__set_me__

# [FEATURE] Sentry DSN for frontend error reporting.
# Absent → crashes not sent to Sentry; app still works.
VITE_SENTRY_DSN=__set_me__

# [FEATURE] Whoop OAuth client ID for Whoop health integration.
# Absent → Whoop connect unavailable; has || '' fallback.
VITE_WHOOP_CLIENT_ID=__set_me__

# [FEATURE] Garmin OAuth consumer key for Garmin integration.
# Absent → Garmin connect unavailable; has || '' fallback.
VITE_GARMIN_CONSUMER_KEY=__set_me__

# [DEV] Auto-login email for seeded demo account in simulator builds.
# Only active when MODE=development (build:sim). Empty = normal auth flow.
VITE_DEV_EMAIL=

# [DEV] Auto-login password for seeded demo account. Same gating as above.
VITE_DEV_PASSWORD=


# =============================================================================
# SERVER VARS  (process.env.* in api/ serverless functions)
# Set in Vercel dashboard → Settings → Environment Variables.
# NOT needed in .env.local unless running `vercel dev` locally.
# check-env does NOT verify these (they aren't in .env.local).
# =============================================================================

# [CORE] Anthropic API key — all Claude AI calls in api/claude.js.
ANTHROPIC_API_KEY=__set_me__

# [BOOT-server] Supabase project URL for server-side DB access.
SUPABASE_URL=__set_me__

# [BOOT-server] Supabase service-role key (full DB access; server-only).
SUPABASE_SERVICE_KEY=__set_me__

# [FEATURE] USDA FoodData Central API key for nutritional data.
USDA_API_KEY=__set_me__

# [FEATURE] Google Places API key for restaurant search (Restaurant AI).
GOOGLE_PLACES_KEY=__set_me__

# [FEATURE] Resend API key for transactional email.
RESEND_API_KEY=__set_me__

# [FEATURE] Sender address for outbound email via Resend.
FROM_EMAIL=__set_me__

# [FEATURE] Reply-to address for outbound email via Resend.
REPLY_TO_EMAIL=__set_me__

# [FEATURE] RevenueCat webhook signing secret.
REVENUECAT_WEBHOOK_SECRET=__set_me__

# [FEATURE] Strava OAuth client secret (server-side).
STRAVA_CLIENT_SECRET=__set_me__

# [FEATURE] Strava webhook verification token.
STRAVA_WEBHOOK_VERIFY_TOKEN=__set_me__

# [FEATURE] Strava OAuth client ID (referenced in api/ functions).
VITE_STRAVA_CLIENT_ID=__set_me__
